# Free Gmail SMTP setup:
# 1. Enable 2-Step Verification on the Gmail account.
# 2. Create a Google App Password for Mail.
# 3. Copy this file to `.env` and fill in the values below.

SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-gmail-address@gmail.com
SMTP_PASS=your-16-char-app-password
MAIL_FROM=your-gmail-address@gmail.com
MAIL_TO=tiaan374@gmail.com

# Optional: override the EHLO domain used when connecting to the SMTP server.
# Defaults to bossiesgym.co.za — change this if deploying under a different domain.
# SMTP_EHLO_HOST=bossiesgym.co.za

# Optional: override the HTTP server port.
# Defaults to 3001 in development (NODE_ENV != production) and 5173 in production.
# PORT=5173

# ─── Analytics (Supabase) ────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...
VITE_DASHBOARD_PASS=your-dashboard-passphrase
